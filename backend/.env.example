# ─── Database ────────────────────────────────────────────
DATABASE_URL="mysql://root:PASSWORD_KAMU@localhost:3306/leaderboard"

# ─── JWT (WAJIB: minimal 20 karakter, gunakan random string) ─
JWT_SECRET="ganti-dengan-random-string-panjang-minimal-32-karakter"

# ─── Server ──────────────────────────────────────────────
PORT=4000
NODE_ENV=development
# Production: NODE_ENV=production

# ─── CORS (comma separated, TANPA trailing slash) ───────
# Development:
ALLOWED_ORIGINS="http://localhost:3000,http://localhost:3001"
# Production:
# ALLOWED_ORIGINS="https://month.domain.com,https://week.domain.com,https://dash.domain.com"

# ─── API Security (WAJIB ganti untuk production) ────────
API_SECRET_HEADER="X-Api-Key"
API_SECRET_VALUE="ganti-dengan-api-key-rahasia-yang-panjang"

# ─── Upload ──────────────────────────────────────────────
UPLOAD_DIR="./uploads"
MAX_FILE_SIZE=5242880

# ─── Trust Proxy (set true di production, di belakang NGINX) ─
TRUST_PROXY=false
# Production: TRUST_PROXY=true
