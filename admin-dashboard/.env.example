# ─── Development ─────────────────────────────────────────
# Tidak perlu diisi, default sudah ke localhost via next.config.mjs rewrite
# NEXT_PUBLIC_API_URL=
# NEXT_PUBLIC_SOCKET_URL=
NEXT_PUBLIC_WEEKLY_URL=http://localhost:3000/mingguan
NEXT_PUBLIC_MONTHLY_URL=http://localhost:3000/bulanan

# ─── Production ──────────────────────────────────────────
# Kosongkan API_URL dan SOCKET_URL (NGINX yang proxy)
# NEXT_PUBLIC_API_URL=
# NEXT_PUBLIC_SOCKET_URL=
# NEXT_PUBLIC_WEEKLY_URL=https://week.domain.com
# NEXT_PUBLIC_MONTHLY_URL=https://month.domain.com
